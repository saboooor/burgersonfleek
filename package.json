{
  "name": "burgersonfleek",
  "homepage": "https://burgersonfleek.ca",
  "description": "Burgers on Fleek website",
  "engines": {
    "node": ">=23.11.0"
  },
  "type": "module",
  "author": "saboooor",
  "scripts": {
    "build": "wrangler types && qwik build",
    "build.client": "vite build",
    "build.preview": "vite build --ssr src/entry.preview.tsx",
    "build.server": "qwik check-client src dist && vite build -c adapters/cloudflare-pages/vite.config.ts",
    "build.types": "tsc --noEmit",
    "cf-typegen": "wrangler types",
    "deploy": "wrangler deploy",
    "fmt": "prettier --write .",
    "fmt.check": "prettier --check .",
    "lint": "eslint \"src/**/*.ts*\"",
    "preview": "qwik build preview && vite preview",
    "serve": "wrangler dev",
    "start": "vite --mode ssr --host",
    "start.debug": "node --inspect-brk ./node_modules/vite/bin/vite.js --mode ssr --forcenode --inspect-brk ./node_modules/vite/bin/vite.js --mode ssr --force",
    "qwik": "qwik"
  },
  "sideEffects": false,
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@luminescent/icons-qwik": "0.1.1",
    "@luminescent/ui": "^7.0.1",
    "@luminescent/ui-qwik": "7.0.0-3",
    "@qwik.dev/core": "2.0.0-beta.37",
    "@qwik.dev/router": "2.0.0-beta.37",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "latest",
    "@types/three": "^0.185.0",
    "eslint": "10.5.0",
    "eslint-plugin-qwik": "2.0.0-beta.37",
    "globals": "^17.7.0",
    "lucide-icons-qwik": "1.16.0-qwik-v2",
    "simple-icons-qwik": "16.19.0-qwik-v2",
    "tailwindcss": "4.3.1",
    "three": "^0.185.0",
    "ts-morph": "^28.0.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.8.3",
    "typescript-eslint": "^8.62.0",
    "undici": "8.5.0",
    "vite": "7",
    "vite-tsconfig-paths": "^6.1.1",
    "wrangler": "^4.105.0"
  }
}
